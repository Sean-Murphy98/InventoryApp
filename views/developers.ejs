<!-- games.ejs -->
<html>
  <head>
    <title>Developers</title>
  </head>
  <body>
    <% developers.forEach((developer, index) => { %>
        <h2 ><%= developer.title %></h2>
        <span><%= developer.games%></span>
        
        <button><a href=<%="/" + developer.id%>>Edit developer</a></button>

        <form action=<%="/" + developer.id + %> method="POST" onsubmit="return confirm('Are you sure you want to delete this?');">
            <input type="hidden" name="csrf_token" value="xyz123"> <!-- CSRF Protection -->
            <button type="submit" style="color: red;">Delete Developer</button>
        </form>
        <button><a href="/new">Add new developer</a></button>
  </body>
</html>