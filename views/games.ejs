<!-- games.ejs -->
<html>
  <head>
    <title>Games</title>
  </head>
  <body><% games.forEach((game, index) => { %>
    <% let deleteString = "/games/delete/" + game.id %>
        <h2 ><%= game.title %></h2>
        <% if (!single) {  %>
        <span><%= game.genre%></span>
        <p> <%= game.developer %></p>
        
        <form action=<%="games/" + game.id%> method="GET">
  <button type="submit">Edit game</button>
</form>
      <% }  else { 
        deleteString = "delete/" + game.id; %>
        <form action=<%=  game.id %> method="POST" >
            <input type="text" name="title" id="title" value="<%= game.title %>" required />
            <label for="developer">Developer:</label>
            <select name="developer" id="developerList">
              <% developers.forEach((developer) => {
                console.log(developer.name)%>
                <option value=<%=developer.id%>><%= developer.name %></option>
                <% }) %>
            </select>
            <label for="genre">Genre:</label>
            <select name="genre" id="genreList">
              <% genres.forEach((genre) => {
                console.log(genre.title)%>
                <option value=<%=genre.title%>><%= genre.title %></option>
                <% }) %>
            </select>
            <button type="submit">Submit</button>
        </form>
        <% } %>
        <form action=<%= deleteString %> method="POST" onsubmit="return confirm('Are you sure you want to delete this?');">
            <input type="hidden" name="csrf_token" value="xyz123"> <!-- CSRF Protection -->
            <button type="submit" style="color: red;">Delete game</button>
        </form>
        <% }); %>
        <button><a href="games/new">Add new game</a></button></body>
</html>
